{
	"name": "Allowance Questboard Environment",
  "build": {
    "dockerfile": "../Dockerfile"
  },
  "customizations": {
    "vscode": {
      "extensions": [
        "Dart-Code.dart-code",
        "Dart-Code.flutter",
        "ms-azuretools.vscode-docker",
        "mhutchie.git-graph",
        "GitHub.copilot",
        "jebbs.plantuml"
      ],
      "settings": {
        "dart.flutterRunAdditionalArgs": [
          "--release",
          "-d web-server",
          "--web-hostname=0.0.0.0",
          "--web-port=3000"
        ]
      }
    }
  },
  "forwardPorts": [3000]
}